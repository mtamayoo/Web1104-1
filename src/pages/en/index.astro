---
/**
 * src/pages/en/index.astro — English locale.
 * Served at: /Web1104-1/en/
 */
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Apartment from '../../components/Apartment.astro';
import Amenities from '../../components/Amenities.astro';
import SantaFe from '../../components/SantaFe.astro';
import Gallery from '../../components/Gallery.astro';
import Location from '../../components/Location.astro';
// import Materials from '../../components/Materials.astro'; // temporarily hidden — re-enable when PDFs are ready
import Booking from '../../components/Booking.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n/utils';
import type { Locale } from '../../i18n/utils';

const locale: Locale = (Astro.currentLocale as Locale) ?? 'en';
const t = useTranslations(locale);
---

<Layout
  locale={locale}
  title={t('meta.title')}
  description={t('meta.description')}
  ogTitle={t('meta.og_title')}
  ogDescription={t('meta.og_description')}
>
  <Nav locale={locale} />
  <main id="main-content">
    <Hero      locale={locale} />
    <Apartment locale={locale} />
    <Amenities locale={locale} />
    <SantaFe   locale={locale} />
    <Gallery   locale={locale} />
    <Location  locale={locale} />
    {/* Materials section temporarily hidden — re-enable when PDFs are ready */}
    {/* <Materials locale={locale} /> */}
    <Booking   locale={locale} />
  </main>
  <Footer locale={locale} />
</Layout>
