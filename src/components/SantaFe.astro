---
/**
 * SantaFe.astro — Destination section: Santa Fe de Antioquia.
 * RF-08: nearby attractions grid (6 verified points of interest).
 * Section 3: "Reforzar atractivo turístico". IA-07.
 * CT-18: slogan "Un oasis familiar en el corazón de Antioquia".
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Family activity highlights
const highlights = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    label: { es: 'Centro histórico colonial', en: 'Colonial historic centre', fr: 'Centre historique colonial' },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
    label: { es: 'Iglesias centenarias', en: 'Centuries-old churches', fr: 'Églises centenaires' },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" /></svg>`,
    label: { es: 'Paseos en bote por el río Cauca', en: 'Boat trips on the Cauca River', fr: 'Sorties en bateau sur le río Cauca' },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" /></svg>`,
    label: { es: 'Clima cálido todo el año', en: 'Warm climate year-round', fr: 'Climat chaud toute l\'année' },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /></svg>`,
    label: { es: 'Gastronomía local', en: 'Local gastronomy', fr: 'Gastronomie locale' },
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>`,
    label: { es: 'Aventura y naturaleza', en: 'Adventure and nature', fr: 'Aventure et nature' },
  },
] as const;

const currentLabels = highlights.map((h) => h.label[locale as keyof typeof highlights[0]['label']] || h.label['es']);

// Nearby attractions — verified public info, distances approximate
const attractions = [
  {
    name:        { es: 'Centro Histórico y Plaza Mayor',                         en: 'Historic Centre & Plaza Mayor',                           fr: 'Centre Historique et Plaza Mayor' },
    description: { es: 'Corazón colonial del pueblo: cafés, comercio y arquitectura declarada Monumento Nacional.',
                   en: 'The colonial heart of the town: cafés, shops and architecture declared a National Monument.',
                   fr: 'Cœur colonial du bourg : cafés, commerces et architecture classée Monument National.' },
    distance:    { es: 'A 4 cuadras a pie', en: '4 blocks on foot', fr: 'À 4 rues à pied' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
  },
  {
    name:        { es: 'Catedral Basílica de la Inmaculada Concepción',          en: 'Basilica Cathedral of the Immaculate Conception',          fr: 'Cathédrale Basilique de l\'Immaculée Conception' },
    description: { es: 'Imponente catedral neoclásica del siglo XIX en la plaza principal.',
                   en: 'Imposing 19th-century neoclassical cathedral on the main square.',
                   fr: 'Imposante cathédrale néoclassique du XIXe siècle sur la place principale.' },
    distance:    { es: 'Centro histórico', en: 'Historic centre', fr: 'Centre historique' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>`,
  },
  {
    name:        { es: 'Puente de Occidente',                                    en: 'Puente de Occidente',                                     fr: 'Pont de l\'Occident' },
    description: { es: 'Puente colgante del siglo XIX sobre el río Cauca; Monumento Nacional y joya de la ingeniería.',
                   en: '19th-century suspension bridge over the Cauca River; a National Monument and engineering landmark.',
                   fr: 'Pont suspendu du XIXe siècle sur le río Cauca ; Monument National et chef-d\'œuvre d\'ingénierie.' },
    distance:    { es: '~6 km (aprox. 15 min en carro)', en: '~6 km (approx. 15 min by car)', fr: '~6 km (env. 15 min en voiture)' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  },
  {
    name:        { es: 'Museo Juan del Corral',                                  en: 'Juan del Corral Museum',                                  fr: 'Musée Juan del Corral' },
    description: { es: 'Museo de historia en una casona colonial; arte, piezas indígenas y patrimonio regional.',
                   en: 'History museum in a colonial mansion; art, indigenous artefacts and regional heritage.',
                   fr: 'Musée d\'histoire dans une demeure coloniale ; art, pièces autochtones et patrimoine régional.' },
    distance:    { es: 'Centro histórico', en: 'Historic centre', fr: 'Centre historique' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  },
  {
    name:        { es: 'Iglesia de Santa Bárbara',                               en: 'Santa Bárbara Church',                                    fr: 'Église Sainte-Barbe' },
    description: { es: 'Templo de estilo barroco con altares coloniales ornamentados.',
                   en: 'Baroque-style church with ornate colonial altars.',
                   fr: 'Église de style baroque avec des autels coloniaux ornés.' },
    distance:    { es: 'Centro histórico', en: 'Historic centre', fr: 'Centre historique' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
  },
  {
    name:        { es: 'Parque Acuático Kanaloa',                                en: 'Kanaloa Water Park',                                      fr: 'Parc Aquatique Kanaloa' },
    description: { es: 'Parque de agua ideal para planes en familia con toboganes y atracciones.',
                   en: 'Water park ideal for family outings with slides and attractions.',
                   fr: 'Parc aquatique idéal pour les sorties en famille avec toboggans et attractions.' },
    distance:    { es: '~3,4 km', en: '~3.4 km', fr: '~3,4 km' },
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
  },
];

const currentAttractions = attractions.map((a) => ({
  name:        a.name[locale as keyof typeof a.name]        || a.name['es'],
  description: a.description[locale as keyof typeof a.description] || a.description['es'],
  distance:    a.distance[locale as keyof typeof a.distance] || a.distance['es'],
  icon:        a.icon,
}));
---

<section
  id="santa-fe"
  aria-labelledby="santafe-heading"
  class="bg-surface px-4 py-20"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center gap-3">
      <span class="h-1 w-12 rounded-full bg-primary" aria-hidden="true"></span>
      <h2
        id="santafe-heading"
        class="font-heading text-3xl font-bold text-neutral md:text-4xl"
      >
        {t('santafe.heading')}
      </h2>
    </div>
    <p class="mt-3 text-xl font-medium text-secondary">{t('santafe.subtitle')}</p>

    <div class="mt-8 grid gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Description text -->
      <div class="space-y-5">
        <p class="text-lg leading-relaxed text-neutral/80">{t('santafe.description')}</p>

        <h3 class="mt-8 font-heading text-xl font-bold text-neutral">
          {t('santafe.activities_heading')}
        </h3>
        <p class="text-lg leading-relaxed text-neutral/80">{t('santafe.activities')}</p>
      </div>

      <!-- Activity highlights grid -->
      <ul class="grid grid-cols-2 gap-4 self-start" role="list">
        {highlights.map(({ icon }, i) => (
          <li class="flex items-center gap-3 rounded-xl border border-neutral/10 bg-white p-4 shadow-sm">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/10 text-secondary" aria-hidden="true" set:html={icon} />
            <span class="text-sm font-medium leading-tight text-neutral">{currentLabels[i]}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Nearby attractions grid -->
    <div class="mt-14">
      <h3 class="font-heading text-2xl font-bold text-neutral">
        {t('santafe.visit_heading')}
      </h3>
      <ul class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" role="list">
        {currentAttractions.map(({ name, description, distance, icon }) => (
          <li class="flex flex-col rounded-xl border border-neutral/10 bg-white p-5 shadow-sm">
            <div class="flex items-start gap-3">
              <span
                class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10 text-secondary"
                aria-hidden="true"
                set:html={icon}
              />
              <p class="font-heading font-bold leading-snug text-neutral">{name}</p>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-neutral/70">{description}</p>
            <span class="mt-3 inline-block self-start rounded-full bg-secondary/10 px-3 py-0.5 text-xs font-medium text-secondary">
              {distance}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Tagline (CT-17) -->
    <p class="mt-10 text-right font-heading text-xl font-bold italic text-secondary no-select">
      {t('santafe.tagline')}
    </p>
  </div>
</section>
