---
/**
 * LanguagePicker.astro — Locale switcher (es / en / fr).
 * RF-02: language switcher + first-visit browser-language detection.
 * Detection uses sessionStorage only (no cookies, no personal data) — S9-06.
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BASE_PATH } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const base = BASE_PATH.replace(/\/$/, '');

// Inline SVG flags — render identically on every OS (Windows has no emoji flag font).
// Each SVG is 20×14 px; border-radius + overflow:hidden clips bands to rounded rectangle.
const FLAG_CO = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" width="20" height="14" style="display:inline-block;vertical-align:middle;border-radius:2px;overflow:hidden;flex-shrink:0"><rect x="0" y="0" width="20" height="7" fill="#FCD116"/><rect x="0" y="7" width="20" height="3.5" fill="#003893"/><rect x="0" y="10.5" width="20" height="3.5" fill="#CE1126"/><rect x="0.25" y="0.25" width="19.5" height="13.5" rx="1.75" fill="none" stroke="black" stroke-opacity="0.12" stroke-width="0.5"/></svg>`;
const FLAG_GB = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" width="20" height="14" style="display:inline-block;vertical-align:middle;border-radius:2px;overflow:hidden;flex-shrink:0"><rect width="20" height="14" fill="#012169"/><line x1="0" y1="0" x2="20" y2="14" stroke="#fff" stroke-width="3.5"/><line x1="20" y1="0" x2="0" y2="14" stroke="#fff" stroke-width="3.5"/><line x1="0" y1="0" x2="20" y2="14" stroke="#C8102E" stroke-width="1.5"/><line x1="20" y1="0" x2="0" y2="14" stroke="#C8102E" stroke-width="1.5"/><line x1="10" y1="0" x2="10" y2="14" stroke="#fff" stroke-width="5"/><line x1="0" y1="7" x2="20" y2="7" stroke="#fff" stroke-width="5"/><line x1="10" y1="0" x2="10" y2="14" stroke="#C8102E" stroke-width="3"/><line x1="0" y1="7" x2="20" y2="7" stroke="#C8102E" stroke-width="3"/><rect x="0.25" y="0.25" width="19.5" height="13.5" rx="1.75" fill="none" stroke="black" stroke-opacity="0.12" stroke-width="0.5"/></svg>`;
const FLAG_FR = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 14" width="20" height="14" style="display:inline-block;vertical-align:middle;border-radius:2px;overflow:hidden;flex-shrink:0"><rect x="0" y="0" width="7" height="14" fill="#0055A4"/><rect x="7" y="0" width="6" height="14" fill="#FFFFFF"/><rect x="13" y="0" width="7" height="14" fill="#EF4135"/><rect x="0.25" y="0.25" width="19.5" height="13.5" rx="1.75" fill="none" stroke="black" stroke-opacity="0.12" stroke-width="0.5"/></svg>`;

const options: { locale: Locale; hreflang: string; label: string; href: string; flag: string }[] = [
  { locale: 'es', hreflang: 'es-CO', label: 'ES', href: `${base}/`,    flag: FLAG_CO },
  { locale: 'en', hreflang: 'en-US', label: 'EN', href: `${base}/en/`, flag: FLAG_GB },
  { locale: 'fr', hreflang: 'fr-FR', label: 'FR', href: `${base}/fr/`, flag: FLAG_FR },
];
---

<nav aria-label={t('lang.pick')} class="flex items-center gap-0.5 text-sm">
  {options.map(({ locale: l, hreflang, label, href, flag }) => (
    <a
      href={href}
      hreflang={hreflang}
      aria-current={l === locale ? 'page' : undefined}
      lang={hreflang}
      title={t(`lang.${l}`)}
      class:list={[
        'flex items-center gap-1 rounded-md px-2 py-1 font-medium transition-colors duration-150',
        l === locale
          ? 'bg-primary text-neutral shadow-sm'
          : 'text-white/80 hover:bg-white/10 hover:text-white',
      ]}
    >
      <span aria-hidden="true" set:html={flag}></span>
      <span>{label}</span>
    </a>
  ))}
</nav>

<!--
  RF-02: first-visit browser language detection.
  Uses sessionStorage (no cookies, no personal data — S9-06).
  Only redirects when on the default (Spanish) locale and the browser language
  is English or French. Marks the session as "done" immediately so it never
  redirects more than once per tab session.
-->
<script define:vars={{ base, locale }}>
  (function () {
    const KEY = 'dis-lang-detected';
    if (sessionStorage.getItem(KEY)) return;
    sessionStorage.setItem(KEY, '1');

    if (locale !== 'es') return; // only redirect from default locale page

    const browserLang = (navigator.language || '').toLowerCase();
    if (browserLang.startsWith('fr')) {
      window.location.replace(base + '/fr/');
    } else if (browserLang.startsWith('en')) {
      window.location.replace(base + '/en/');
    }
  })();
</script>
