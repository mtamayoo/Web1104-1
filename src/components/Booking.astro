---
/**
 * Booking.astro — Conversion section: CTA buttons to Booking (primary) and Airbnb (secondary).
 * RF-04: Booking must be visually more prominent.
 * CT-16: slogan "Descanso, comodidad y diversión en familia".
 * CT-19: slogan "Hasta 8 huéspedes, infinitos recuerdos".
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BOOKING_URL, AIRBNB_URL, VRBO_URL } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  id="reservar"
  aria-labelledby="booking-heading"
  class="relative overflow-hidden bg-neutral px-4 py-24"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_var(--color-primary)_0%,_transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,_var(--color-secondary)_0%,_transparent_60%)]"></div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <!-- Tagline (CT-16) -->
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary/80 no-select">
      {t('booking.tagline')}
    </p>

    <h2
      id="booking-heading"
      class="font-heading text-3xl font-bold text-white md:text-5xl"
    >
      {t('booking.heading')}
    </h2>

    <!-- Subtitle (CT-19) -->
    <p class="mt-4 text-xl text-white/70 no-select">
      {t('booking.subtitle')}
    </p>

    <!-- CTAs (RF-04: equal-height/equal-width 3-up grid; label shown once above) -->
    <p class="mt-12 text-sm font-semibold uppercase tracking-widest text-primary/80 no-select">
      {t('booking.book_on_label')}
    </p>
    <div class="mt-3 grid w-full grid-cols-1 gap-2 mx-auto max-w-[16rem] sm:max-w-none sm:grid-cols-3 sm:gap-3">
      <!-- Booking.com -->
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('booking.cta_booking_primary_aria')}
        data-tracking="cta-booking"
      >
        <!-- Calendar mark — Booking.com -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6 2a1 1 0 0 0-1 1v1H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1V3a1 1 0 1 0-2 0v1H7V3a1 1 0 0 0-1-1zm0 5a1 1 0 0 0 0 2h8a1 1 0 1 0 0-2H6z" clip-rule="evenodd"/>
        </svg>
        {t('booking.cta_booking_primary')}
      </a>

      <!-- Airbnb -->
      <a
        href={AIRBNB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('booking.cta_airbnb_secondary_aria')}
        data-tracking="cta-airbnb"
      >
        <!-- Person mark — Airbnb -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-7 9a7 7 0 1 1 14 0H3z" clip-rule="evenodd"/>
        </svg>
        {t('booking.cta_airbnb_secondary')}
      </a>

      <!-- Vrbo -->
      <a
        href={VRBO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('booking.cta_vrbo_aria')}
        data-tracking="cta-vrbo"
      >
        <!-- House mark — Vrbo -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10.707 2.293a1 1 0 0 0-1.414 0l-7 7a1 1 0 0 0 1.414 1.414L4 10.414V17a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-6.586l.293.293a1 1 0 0 0 1.414-1.414l-7-7z"/>
        </svg>
        {t('booking.cta_vrbo')}
      </a>
    </div>

    <!-- Trust note -->
    <p class="mt-10 text-sm text-white/30">
      ✦ Apartasol 1104 · Citadela Di Sole · Santa Fe de Antioquia, Colombia
    </p>
  </div>
</section>
