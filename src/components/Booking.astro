---
/**
 * Booking.astro — Conversion section: CTA buttons to Booking (primary) and Airbnb (secondary).
 * RF-04: Booking must be visually more prominent.
 * CT-16: slogan "Descanso, comodidad y diversión en familia".
 * CT-19: slogan "Hasta 8 huéspedes, infinitos recuerdos".
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BOOKING_URL, AIRBNB_URL } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  id="reservar"
  aria-labelledby="booking-heading"
  class="relative overflow-hidden bg-neutral px-4 py-24"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-5" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_var(--color-primary)_0%,_transparent_60%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_50%,_var(--color-secondary)_0%,_transparent_60%)]"></div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <!-- Tagline (CT-16) -->
    <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary/80 no-select">
      {t('booking.tagline')}
    </p>

    <h2
      id="booking-heading"
      class="font-heading text-3xl font-bold text-white md:text-5xl"
    >
      {t('booking.heading')}
    </h2>

    <!-- Subtitle (CT-19) -->
    <p class="mt-4 text-xl text-white/70 no-select">
      {t('booking.subtitle')}
    </p>

    <!-- CTAs (RF-04: Booking prominently primary) -->
    <div class="mt-12 flex flex-col items-center gap-6 sm:flex-row sm:justify-center">
      <!-- Primary CTA: Booking -->
      <div class="flex flex-col items-center gap-2">
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-primary px-10 py-5 text-lg font-bold text-white shadow-2xl ring-4 ring-primary/20 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          aria-label={t('booking.cta_booking_primary')}
          data-tracking="cta-booking"
        >
          <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M3 4a1 1 0 000 2h1v10a1 1 0 001 1h10a1 1 0 001-1V6h1a1 1 0 100-2H3zm5 4a1 1 0 112 0v5a1 1 0 11-2 0V8zm4 0a1 1 0 112 0v5a1 1 0 11-2 0V8z"/>
          </svg>
          {t('booking.cta_booking_primary')}
        </a>
        <span class="text-xs text-white/40">{t('booking.booking_label')}</span>
      </div>

      <!-- Secondary CTA: Airbnb -->
      <div class="flex flex-col items-center gap-2">
        <a
          href={AIRBNB_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-[18px] font-semibold text-white/90 transition hover:border-white hover:bg-white/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white"
          aria-label={t('booking.cta_airbnb_secondary')}
          data-tracking="cta-airbnb"
        >
          {t('booking.cta_airbnb_secondary')}
        </a>
        <span class="text-xs text-white/40">{t('booking.airbnb_label')}</span>
      </div>
    </div>

    <!-- Trust note -->
    <p class="mt-10 text-sm text-white/30">
      ✦ Apartasol 1104 · Citadela DI Sole · Santa Fe de Antioquia, Colombia
    </p>
  </div>
</section>
