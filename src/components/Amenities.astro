    color: 'text-neutral/60',
    bg: 'bg-neutral/5',
  },
] as const;
---

<section
  id="amenidades"
  aria-labelledby="amenities-heading"
  class="bg-secondary/5 px-4 py-20"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center gap-3">
      <span class="h-1 w-12 rounded-full bg-secondary" aria-hidden="true"></span>
      <h2
        id="amenities-heading"
        class="font-heading text-3xl font-bold text-neutral md:text-4xl"
      >
        {t('amenities.heading')}
      </h2>
    </div>
    <p class="mt-3 text-lg text-neutral/70">{t('amenities.subtitle')}</p>

    <ul class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4" role="list">
      {items.map(({ key, icon, color, bg }) => (
        <li class="flex flex-col items-center gap-4 rounded-2xl bg-white p-6 text-center shadow-sm transition hover:shadow-md hover:-translate-y-0.5">
          <span
            class={`flex h-16 w-16 items-center justify-center rounded-full ${bg} ${color}`}
            aria-hidden="true"
            set:html={icon}
          />
          <span class="text-sm font-semibold leading-tight text-neutral">{t(key)}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
