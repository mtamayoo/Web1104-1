---

<section
  id="amenidades"
  aria-labelledby="amenities-heading"
  class="bg-secondary/5 px-4 py-20"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center gap-3">
      <span class="h-1 w-12 rounded-full bg-secondary" aria-hidden="true"></span>
      <h2
        id="amenities-heading"
        class="font-heading text-3xl font-bold text-neutral md:text-4xl"
      >
        {t('amenities.heading')}
      </h2>
    </div>
    <p class="mt-3 text-lg text-neutral/70">{t('amenities.subtitle')}</p>

    <ul class="mt-12 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4" role="list">
      {items.map(({ key, icon, image, w1 = 600, w2 = 1000 }) => (
        <li class="group relative min-h-52 overflow-hidden rounded-2xl bg-neutral text-center shadow-sm">
          <img
            src={galleryAsset(image, w1)}
            srcset={`${galleryAsset(image, w1)} ${w1}w, ${galleryAsset(image, w2)} ${w2}w`}
            sizes="(min-width: 1024px) calc(25vw - 2rem), (min-width: 640px) calc(33vw - 2rem), calc(50vw - 1rem)"
            alt=""
            loading="lazy"
            decoding="async"
            width="1000"
            height="750"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/70 via-black/10 to-transparent" aria-hidden="true"></div>
          <div class="relative flex h-full min-h-52 flex-col items-center justify-end gap-4 p-6">
            <span
              class="flex h-16 w-16 items-center justify-center rounded-full bg-black/35 text-white backdrop-blur-sm"
              aria-hidden="true"
              set:html={icon}
            />
            <span class="text-sm font-bold leading-tight text-white" style="text-shadow: 0 1px 3px rgb(0 0 0 / 0.85);">{t(key)}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
