---
/**
 * Amenities.astro — Complex amenities: pools, slides, gym, sports, playground, security.
 * Section 3 table: "Mostrar ventajas del complejo". IA-06.
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

export interface Props {
