---
/**
 * Amenities.astro — Complex amenities: pools, slides, gym, sports, playground, security.
 * Section 3 table: "Mostrar ventajas del complejo". IA-06.
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BASE_PATH } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = BASE_PATH.replace(/\/$/, '');
const galleryAsset = (name: string, width: number) => `${base}/galeria/${name}-${width}.webp`;

