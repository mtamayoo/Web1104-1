---
/**
 * Hero.astro — Full-screen hero with CSS crossfade real-photo montage, slogan, and CTAs.
 * RF-03: animated photos, slogan "Te va a encantar", Booking (primary) + Airbnb + Vrbo (secondary).
 * RF-04: Booking CTA is visually more prominent.
 * RF-06: "Di Sole" brand overlay on all slides.
 * PI-02: right-click / drag disabled on images (via global CSS + contextmenu listener).
 * Performance: CSS-only animation (no JS for slides), first img eager for LCP.
 * prefers-reduced-motion: animation disabled via global CSS media query.
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BOOKING_URL, AIRBNB_URL, VRBO_URL, BASE_PATH } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = BASE_PATH.replace(/\/$/, '');
const galleryAsset = (name: string, width: number) => `${base}/galeria/${name}-${width}.webp`;

const heroWidths = [1024, 1600, 1920] as const;
const slides = [
  { name: 'salon-dia', delay: '0s' },
  { name: 'balcon', delay: '6s' },
  { name: 'piscina-tobogan', delay: '12s' },
  { name: 'salon-noche', delay: '18s' },
] as const;
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative flex min-h-screen items-center justify-center overflow-hidden bg-neutral"
>
  <!-- ── Slideshow (decorative, aria-hidden) ───────────────────────── -->
  <div class="absolute inset-0" aria-hidden="true">
    {slides.map(({ name, delay }, i) => (
      <div
        class="hero-slide"
        style={`animation-delay: ${delay};`}
      >
        <img
          src={galleryAsset(name, 1920)}
          srcset={heroWidths.map((width) => `${galleryAsset(name, width)} ${width}w`).join(', ')}
          sizes="100vw"
          alt=""
          width="1920"
          height="1080"
          class="absolute inset-0 h-full w-full object-cover"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
          decoding={i === 0 ? 'sync' : 'async'}
        />
      </div>
    ))}
  </div>

  <!-- Subtle dark scrim for text contrast over real photos -->
  <div class="absolute inset-0 bg-neutral/45" aria-hidden="true"></div>

  <!-- RF-06: Official logo watermark overlay (replaces text "✦ Di Sole") -->
  <div
    class="absolute bottom-6 right-6 z-10 no-select select-none"
    aria-hidden="true"
  >
    <img
      src={`${base}/brand/logo-disole-lockup-160.webp`}
      srcset={`${base}/brand/logo-disole-lockup-160.webp 160w, ${base}/brand/logo-disole-lockup-320.webp 320w`}
      sizes="(max-width: 640px) 48px, 64px"
      alt=""
      width="160"
      height="149"
      class="h-12 w-auto sm:h-16 rounded-md bg-black/30 p-2 backdrop-blur-sm drop-shadow-lg"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- ── Hero content ─────────────────────────────────────────────── -->
  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center text-white">
    <!-- PI-06: no-select on key promotional text -->
    <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary no-select">
      Apartasol 1104 · Citadela Di Sole · Santa Fe de Antioquia
    </p>
    <h1
      id="hero-heading"
      class="font-heading font-bold leading-tight no-select drop-shadow-lg whitespace-nowrap text-[clamp(1.5rem,7.5vw,4.5rem)]"
    >
      {t('hero.slogan')}
    </h1>
    <p class="mt-5 text-xl font-light no-select drop-shadow md:text-2xl">
      {t('hero.subtitle')}
    </p>

    <!-- CTAs — RF-04: equal-height/equal-width 3-up grid; label shown once above -->
    <p class="mt-6 text-sm font-semibold uppercase tracking-widest text-white/60 no-select sm:mt-10">
      {t('hero.book_on_label')}
    </p>
    <div class="mt-3 grid w-full grid-cols-1 gap-2 sm:grid-cols-3 sm:gap-3">
      <!-- Booking.com -->
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('hero.cta_booking_aria')}
      >
        <!-- Calendar mark — Booking.com -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M6 2a1 1 0 0 0-1 1v1H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1V3a1 1 0 1 0-2 0v1H7V3a1 1 0 0 0-1-1zm0 5a1 1 0 0 0 0 2h8a1 1 0 1 0 0-2H6z" clip-rule="evenodd"/>
        </svg>
        {t('hero.cta_booking')}
      </a>

      <!-- Airbnb -->
      <a
        href={AIRBNB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('hero.cta_airbnb_aria')}
      >
        <!-- Person mark — Airbnb -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-7 9a7 7 0 1 1 14 0H3z" clip-rule="evenodd"/>
        </svg>
        {t('hero.cta_airbnb')}
      </a>

      <!-- Vrbo -->
      <a
        href={VRBO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-12 w-full items-center justify-center gap-2 whitespace-nowrap rounded-full bg-primary px-4 text-sm font-bold text-neutral shadow-2xl ring-2 ring-primary/35 transition hover:bg-primary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white sm:h-14 sm:px-6 sm:text-base"
        aria-label={t('hero.cta_vrbo_aria')}
      >
        <!-- House mark — Vrbo -->
        <svg class="h-4 w-4 shrink-0 sm:h-5 sm:w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10.707 2.293a1 1 0 0 0-1.414 0l-7 7a1 1 0 0 0 1.414 1.414L4 10.414V17a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2a1 1 0 0 0 1 1h2a1 1 0 0 0 1-1v-6.586l.293.293a1 1 0 0 0 1.414-1.414l-7-7z"/>
        </svg>
        {t('hero.cta_vrbo')}
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-14 flex justify-center" aria-hidden="true">
      <span class="animate-bounce text-white/50">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
        </svg>
      </span>
    </div>
  </div>
</section>

<script>
  // PI-02: disable right-click context menu on hero images (content protection)
  document.querySelectorAll('#hero img').forEach((img) => {
    img.addEventListener('contextmenu', (e) => e.preventDefault());
  });
</script>
