---
/**
 * Materials.astro — PDF reference materials, opened inline in new tab (RF-09).
 * Files in public/materiales/ — marked pending until PDFs are delivered (section 12).
 * All links use target="_blank" rel="noopener noreferrer" (NOT forced download).
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { BASE_PATH } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const base = BASE_PATH.replace(/\/$/, '');

// TODO (owner): replace '#materiales-pendiente' with real PDF paths
// e.g. `${base}/materiales/guia-apartamento.pdf` once files are delivered.
const materials = [
  {
    key: 'materials.apartment_guide',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
  },
  {
    key: 'materials.guest_manual',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
  },
  {
    key: 'materials.regulations',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  },
  {
    key: 'materials.arrival',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
  },
  {
    key: 'materials.tourist_map',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498l4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0z" /></svg>`,
  },
  {
    key: 'materials.restaurants',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.871v-1.5m-6 4.5V19.5m0 0H5.25A2.25 2.25 0 013 17.25v-1.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 15.75v1.5a2.25 2.25 0 01-2.25 2.25H18m-9 0v-2.625c0-.621.504-1.125 1.125-1.125h1.5c.621 0 1.125.504 1.125 1.125V19.5" /></svg>`,
  },
  {
    key: 'materials.activities',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" /></svg>`,
  },
  {
    key: 'materials.faq',
    href: '#materiales-pendiente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-8 w-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" /></svg>`,
  },
] as const;
---

<section
  id="materiales"
  aria-labelledby="materials-heading"
  class="bg-neutral/5 px-4 py-20"
>
  <div class="mx-auto max-w-7xl">
    <div class="flex items-center gap-3">
      <span class="h-1 w-12 rounded-full bg-primary" aria-hidden="true"></span>
      <h2
        id="materials-heading"
        class="font-heading text-3xl font-bold text-neutral md:text-4xl"
      >
        {t('materials.heading')}
      </h2>
    </div>
    <p class="mt-3 text-lg text-neutral/70">{t('materials.subtitle')}</p>

    <!-- PDF cards grid (RF-09: open inline in new tab, not forced download) -->
    <ul class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" role="list">
      {materials.map(({ key, href, icon }) => {
        const isPending = href === '#materiales-pendiente';
        return (
          <li>
            {isPending ? (
              <div
                class="flex flex-col items-center gap-3 rounded-xl border border-dashed border-neutral/20 bg-white/50 p-6 text-center opacity-60"
                aria-label={`${t(key)} — ${t('materials.pending')}`}
              >
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-neutral/5 text-neutral/30" aria-hidden="true" set:html={icon} />
                <span class="font-semibold text-sm text-neutral/60">{t(key)}</span>
                <span class="text-xs text-neutral/40">{t('materials.pending')}</span>
              </div>
            ) : (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex flex-col items-center gap-3 rounded-xl border border-neutral/10 bg-white p-6 text-center shadow-sm transition hover:border-secondary hover:shadow-md hover:-translate-y-0.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary"
                aria-label={`${t('materials.open_pdf')}: ${t(key)}`}
              >
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-secondary/10 text-secondary" aria-hidden="true" set:html={icon} />
                <span class="font-semibold text-sm text-neutral">{t(key)}</span>
                <span class="flex items-center gap-1 text-xs text-secondary font-medium">
                  {t('materials.open_pdf')}
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </span>
              </a>
            )}
          </li>
        );
      })}
    </ul>
  </div>
</section>
