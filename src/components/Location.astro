---
/**
 * Location.astro — Exact location map + Google Maps link.
 * RF-07: map showing exact location; button opening Google Maps navigation.
 * RF-08: "Cómo llegar" section with distances placeholder.
 */
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import { GEO_LAT, GEO_LNG, GOOGLE_MAPS_URL } from '../config/site';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Google Maps embed (no API key required for basic embeds)
const MAPS_EMBED_URL =
  `https://maps.google.com/maps?q=${GEO_LAT},${GEO_LNG}&z=15&output=embed`;
---

<section
  id="ubicacion"
  aria-labelledby="location-heading"
  class="mx-auto max-w-7xl px-4 py-20"
>
  <div class="flex items-center gap-3">
    <span class="h-1 w-12 rounded-full bg-secondary" aria-hidden="true"></span>
    <h2
      id="location-heading"
      class="font-heading text-3xl font-bold text-neutral md:text-4xl"
    >
      {t('location.heading')}
    </h2>
  </div>

  <p class="mt-3 text-lg font-medium text-secondary">{t('location.subtitle')}</p>
  <p class="mt-2 text-neutral/80">{t('location.address')}</p>
  <p class="text-sm text-neutral/50">{t('location.coordinates')}</p>

  <!-- RF-07: Google Maps embed -->
  <div class="relative mt-8 aspect-video w-full overflow-hidden rounded-2xl shadow-lg ring-1 ring-neutral/10">
    <iframe
      title={t('location.heading')}
      src={MAPS_EMBED_URL}
      width="100%"
      height="100%"
      class="absolute inset-0 h-full w-full border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      aria-label={t('location.address')}
    ></iframe>
  </div>

  <!-- RF-07: "Abrir en Google Maps" button — URL per spec RF-07 -->
  <a
    href={GOOGLE_MAPS_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-6 inline-flex items-center gap-2 rounded-full bg-secondary px-6 py-3 font-semibold text-white shadow transition hover:bg-secondary-dark hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-secondary"
  >
    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
    </svg>
    {t('location.open_maps')}
    <svg class="h-4 w-4 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
    </svg>
  </a>

  <!-- RF-08: "Cómo llegar" sub-section -->
  <div class="mt-12">
    <h3 class="font-heading text-xl font-bold text-neutral">{t('location.how_to_arrive')}</h3>
    <p class="mt-3 max-w-2xl text-neutral/70">{t('location.how_to_arrive_text')}</p>
  </div>
</section>
